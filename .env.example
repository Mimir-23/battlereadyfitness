# ─── Supabase ───────────────────────────────────────────────────────────────
# Copia este archivo a `.env.local` y pega tus 2 claves del panel de Supabase.
# Las encuentras en: Supabase → tu proyecto → Project Settings → API.
# Ambas son PÚBLICAS y seguras de usar en el frontend (la seguridad real la dan
# las políticas RLS de la base de datos).

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anon-publica
